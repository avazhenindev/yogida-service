# Copy this file to /home/yogida/meditation-service/.env on the Linode/Akamai host.
# Do not commit real production secrets.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-host:5432/meditation
SPRING_DATASOURCE_USERNAME=backend
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_JPA_SHOW_SQL=false

CLOUDFLARE_R2_ACCOUNT_ID=change-me
CLOUDFLARE_R2_ACCESS_KEY_ID=change-me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=change-me
CLOUDFLARE_R2_BUCKET=change-me

APP_AUDIO_PRESIGNED_URL_DURATION_MINUTES=1
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercenta ge=75.0

CLOUDFLARE_R2_PUBLIC_PICTURE_BASE_URL=https://pub-a8da202945d64949991475033b69c36a.r2.dev

APP_SECURITY_JWT_AUDIENCE=yogida
APP_SECURITY_JWT_ISSUER=https://yogida.org/zxcasdqwe/realms/yogida

# RevenueCat integration
APP_REVENUECAT_ENTITLEMENT_ID="Yogida Pro"
APP_REVENUECAT_PREMIUM_PLAN_NAME=PREMIUM
